# Identifiants du service MySQL uniquement (pas de dossier mysql/ dédié dans le repo).
# Copier en .env.prod (non commité) sur le VPS et renseigner de vraies valeurs.
#
# Le backend et le bot ont chacun leur propre .env.prod, à créer à partir de
# leur .env.example respectif (web/backend/.env.example, bot/.env.example) —
# voir docs/C2.1.1-environnement-deploiement.md pour le détail.

MYSQL_ROOT_PASSWORD=change_me
MYSQL_DATABASE=mazworld
MYSQL_USER=mazworld
MYSQL_PASSWORD=change_me
