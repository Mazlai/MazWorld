# Copier en .env.prod (non commité) sur le VPS et renseigner de vraies valeurs.

# --- MySQL ---
MYSQL_ROOT_PASSWORD=change_me
MYSQL_DATABASE=mazworld
MYSQL_USER=mazworld
MYSQL_PASSWORD=change_me

# --- Backend Symfony ---
APP_ENV=prod
APP_SECRET=change_me
DEFAULT_URI=https://mazworld.example.com
DATABASE_URL=mysql://mazworld:change_me@mysql:3306/mazworld?serverVersion=8.0.32&charset=utf8mb4
JWT_PASSPHRASE=change_me
DISCORD_CLIENT_ID=change_me
DISCORD_CLIENT_SECRET=change_me
DISCORD_REDIRECT_URI=https://mazworld.example.com/auth/callback
DISCORD_BOT_TOKEN=change_me
BOT_API_SECRET=change_me
APP_ENCRYPTION_KEY=change_me
CORS_ALLOW_ORIGIN=^https://mazworld\.example\.com$
LOCK_DSN=flock

# --- Bot Discord ---
TOKEN=change_me
BOT_ID=change_me
GUILD_ID=change_me
API_URL=http://nginx
